{
  "name": "block-unsafe-files",
  "target": "push",
  "enforcement": "active",
  "bypass_actors": [],
  "rules": [
    {
      "type": "file_extension_restriction",
      "parameters": {
        "restricted_file_extensions": ["*.exe", "*.dll", "*.zip", "*.tar.gz"]
      }
    },
    {
      "type": "max_file_size",
      "parameters": {
        "max_file_size": 10
      }
    } 
]
}
